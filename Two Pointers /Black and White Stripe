#define allr(v) v.rbegin(), v.rend()
#define MalakA7med ios_base::sync_with_stdio(false);cin.tie(nullptr); cout.tie(nullptr);
#define ll long long
#define pb push_back
#define el "\n"
using namespace std;
void solve() {
	int n, k, ws = 0;
	cin >> n >> k;
	string s; cin >> s;
	for (int i = 0; i <= k-1; i++) {
		if (s[i] == 'W') {
			ws++;
		}
	}
	int ans = ws;
	int l = 0, r = k;
	while (r < n) {
		if (s[l] == 'W') {
			ws--;
		}
		if (s[r] == 'W') {
			ws++;
		}

		ans = min(ans, ws);
		l++;
		r++;
	}
	cout << ans << el;
}
int main() {
	int t; cin >> t;
	while (t--) {
		solve();
	}
	}

