#define allr(v) v.rbegin(), v.rend()
#define MalakA7med ios_base::sync_with_stdio(false);cin.tie(nullptr); cout.tie(nullptr);
#define ll long long
#define pb push_back
#define el "\n"
using namespace std;
void solve() {
	int n; cin >> n;
	string s; cin >> s;

	string ans = "";
	int l = 0;
	ans += s[l];

	int r = l + 1;
	while (r < n) {
		if (s[r] == s[l]) {
			l = r + 1;
			if (l < n) ans += s[l];
			r = l + 1;
		} else {
			r++;
		}
	}

	cout << ans << el;
}

int main() {
	int t; cin >> t;
	while (t--) {
		solve();
	}
}


