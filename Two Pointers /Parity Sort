using namespace std;
void solve() {
	ll n; cin >> n;
	vector<int>v(n), v2;
	for (auto &i : v) cin >> i;
	v2 = v;
	sort(all(v2));
	bool ok = true;
	for (int i = 0; i < n; i++) {
		if ((v[i] % 2) != (v2[i] % 2)) {
			ok = false;
			break;
		}
	}

	cout << (ok ? "YES\n" : "NO\n");
	}

int main() {
	int t; cin >> t;
	while (t--) {
		solve();
	}
